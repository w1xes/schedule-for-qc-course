    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains token\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Response contains email\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('email');",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 2000ms\", () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set(\"token\", pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"manager@gmail.com\",\n    \"password\": \"Qwerty!123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/sign-in",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "sign-in"]
            }
          }
        },
        {
          "name": "POST Sign In with Wrong Password (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Response does not contain token\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.not.have.property('token');",
                  "});",
                  "",
                  "pm.test(\"Response contains error message\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.satisfy((body) => {",
                  "        return body.hasOwnProperty('message') || body.hasOwnProperty('error') || body.hasOwnProperty('status');",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 2000ms\", () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"manager@gmail.com\",\n    \"password\": \"WrongPassword!999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/sign-in",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "sign-in"]
            }
          }
        }
