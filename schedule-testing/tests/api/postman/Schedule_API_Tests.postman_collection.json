                  "    });",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 500ms\", () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer_{{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/semesters/999999",
              "host": ["{{baseUrl}}"],
              "path": ["semesters", "999999"]
            }
          }
        },
        {
